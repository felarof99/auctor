{
  "name": "monorepo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --write --unsafe",
    "clean": "rimraf dist",
    "dashboard:sync": "bun apps/dashboard/scripts/sync-data.ts",
    "dashboard:dev": "bun run dashboard:sync && bun run --cwd apps/dashboard dev",
    "cli:build": "bun build ./apps/cli/src/index.ts --compile --outfile ./bin/auctor",
    "cli:install": "bun run cli:build && mkdir -p \"$HOME/.local/bin\" && mv ./bin/auctor \"$HOME/.local/bin/auctor\" && echo \"Installed auctor to $HOME/.local/bin/auctor\""
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/node": "^24.3.3",
    "bun-types": "^1.3.13",
    "lefthook": "^2.0.12",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  },
  "trustedDependencies": [
    "lefthook"
  ],
  "engines": {
    "bun": "1.3.6",
    "node": "please-use-bun",
    "npm": "please-use-bun",
    "yarn": "please-use-bun",
    "pnpm": "please-use-bun"
  },
  "packageManager": "bun@1.3.6"
}
